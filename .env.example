# Copy to .env next to main.py or export in your shell (never commit real keys).
DEEPSEEK_API_KEY=your_deepseek_api_key

# 火山方舟文生图（封面）。优先 VOLC_ARK_API_KEY；亦可 ARK_API_KEY / SEEDREAM_API_KEY / VOLCANO_ENGINE_API_KEY
# VOLC_ARK_API_KEY=your_ark_api_key
# ARK_API_KEY=your_ark_api_key
# SEEDREAM_API_KEY=legacy_alias_for_ark_key

# 封面所用推理接入点或 model（若 config.yaml image.model 为空则必填）
# VOLC_ARK_IMAGE_MODEL=ep-xxxx 或文档中的模型名

# Optional: OpenAI-compatible base if you use a proxy (default DeepSeek chat endpoint).
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional: Chrome for Playwright (defaults to channel "chrome" if installed)
# CHROME_BINARY=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Playwright 窗口：1/true = 无头；0/false 或留空 = 有窗口。若 OpenClaw/Gateway 已设 PLAYWRIGHT_HEADLESS=1，须在本文件写 PLAYWRIGHT_HEADLESS=0 才能覆盖。
# PLAYWRIGHT_HEADLESS=0

# Set to 0 to skip browser publish (fetch + LLM + image only).
# ENABLE_BROWSER_PUBLISH=1

# Comma-separated platform names from config.yaml (e.g. toutiao only).
# MATRIX_PUBLISH_ONLY=toutiao

# Chrome 持久化登录目录（覆盖 config.yaml，便于与 openclaw browser 或本机路径对齐）
# MATRIX_TOUTIAO_CHROME_USER_DATA_DIR=/path/to/chrome-profile
# MATRIX_CHROME_USER_DATA_DIR=/path/to/chrome-profile

# 指定主题时跳过热搜，直接 DeepSeek 成文后走封面与发布（也可用 python main.py --topic）
# MATRIX_ARTICLE_TOPIC=

# Debug switch (生产模式默认关闭；开启后才允许 fixtures / mock 路径)
# AUTO_HOT_DEBUG=1
#
# Debug: skip real hot APIs (use with ENABLE_BROWSER_PUBLISH=0 first)
# AUTO_HOT_MOCK=1
# AUTO_HOT_FIXTURE=/absolute/path/to/fixture.json

# 跳过热搜 + 跳过 DeepSeek：只发布 JSON 里的 title/body（仅调试，需 AUTO_HOT_DEBUG=1）
# MATRIX_PUBLISH_ARTICLE_JSON=fixtures/publish_only_article.json
